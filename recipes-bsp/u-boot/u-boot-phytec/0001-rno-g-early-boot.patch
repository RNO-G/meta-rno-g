---
 arch/arm/mach-k3/am62x/Kconfig      | 10 +++++
 arch/arm/mach-k3/am62x/am625_init.c | 59 +++++++++++++++++++++++++++++
 2 files changed, 69 insertions(+)

diff --git a/arch/arm/mach-k3/am62x/Kconfig b/arch/arm/mach-k3/am62x/Kconfig
index 81199ada3a1..595f0987b04 100644
--- a/arch/arm/mach-k3/am62x/Kconfig
+++ b/arch/arm/mach-k3/am62x/Kconfig
@@ -65,6 +65,16 @@ config TARGET_VERDIN_AM62_R5
 
 endchoice
 
+config SPL_RNO_G_EARLY_BOOT
+	bool "Enable RNO-G Early Boot behavior"
+	depends on SPL && CPU_V7R
+	default n
+	help
+		Enabling this will drive down the gpios corresponding to the 5V
+		rails on early startup, so long as it's the first power on.
+		To detect first power on, RTC scratch registers are used.
+
+
 source "board/beagle/beagleplay/Kconfig"
 source "board/phytec/phycore_am62x/Kconfig"
 source "board/ti/am62x/Kconfig"
diff --git a/arch/arm/mach-k3/am62x/am625_init.c b/arch/arm/mach-k3/am62x/am625_init.c
index 498bbe45b38..2b76dbf6189 100644
--- a/arch/arm/mach-k3/am62x/am625_init.c
+++ b/arch/arm/mach-k3/am62x/am625_init.c
@@ -22,6 +22,7 @@
 #define REG_K3RTC_KICK0			(RTC_BASE_ADDRESS + 0x70)
 #define REG_K3RTC_KICK1			(RTC_BASE_ADDRESS + 0x74)
 
+
 /* Magic values for lock/unlock */
 #define K3RTC_KICK0_UNLOCK_VALUE	0x83e70b13
 #define K3RTC_KICK1_UNLOCK_VALUE	0x95a4f1e0
@@ -182,6 +183,58 @@ static void fixup_a53_cpu_freq_by_speed_grade(void)
 }
 #endif
 
+#if CONFIG_IS_ENABLED(RNO_G_EARLY_BOOT)
+
+#define RTC_SCRATCH0(J)  (RTC_BASE_ADDRESS + 0x30 + J * 4)
+#define RNO_G_MAGIC_SCRATCH_IDX 7
+#define RNO_G_MAGIC 0xc0fefe
+/** we need to drive low GPIO0_34 and GPIO_40 */
+#define RNO_G_GPIO_SET_DATA_REG 0x600040  /*bank 23*/
+#define RNO_G_GPIO_CLR_DATA_REG 0x600044
+#define RNO_G_GPIO_OUT_DATA_REG 0x60003c
+#define RNO_G_GPIO_DIR_REG 0x600038
+#define RNO_G_GPIO_MASK 0x104  /* bits 2 and 8 */
+#define PADCONFIG_DRIVER_BIT 21
+#define PADCONFIG_GPIO0_34 0xf408c
+#define PADCONFIG_GPIO0_40 0xf40a4
+#endif
+
+static __maybe_unused void rno_g_early_hook(void)
+{
+#if  CONFIG_IS_ENABLED(RNO_G_EARLY_BOOT)
+	/*check RTC magic in last scratch registers */
+	u32 rno_g_magic = readl(RTC_SCRATCH0(RNO_G_MAGIC_SCRATCH_IDX));
+
+	if (rno_g_magic != RNO_G_MAGIC) {
+    u32 val = 0;
+		/* first boot, drive down gpios for 5V enables */
+
+    //set direction to output
+		writel(~RNO_G_GPIO_MASK, RNO_G_GPIO_DIR_REG);
+    //set set bits
+		writel(RNO_G_GPIO_MASK, RNO_G_GPIO_SET_DATA_REG);
+
+
+    //tx enable on padconfigs
+    val = readl(PADCONFIG_GPIO0_34);
+    val &= ~(1u << PADCONFIG_DRIVER_BIT);
+    writel(val, PADCONFIG_GPIO0_34);
+
+    val = readl(PADCONFIG_GPIO0_40);
+    val &= ~(1u << PADCONFIG_DRIVER_BIT);
+    writel(val, PADCONFIG_GPIO0_40);
+
+
+    //write magic to RTC register, unlocking if necessary
+    writel(K3RTC_KICK0_UNLOCK_VALUE, REG_K3RTC_KICK0);
+    writel(K3RTC_KICK1_UNLOCK_VALUE, REG_K3RTC_KICK1);
+		writel(RNO_G_MAGIC, RTC_SCRATCH0(RNO_G_MAGIC_SCRATCH_IDX));
+	}
+#endif
+}
+
+
+
 void board_init_f(ulong dummy)
 {
 	struct udevice *dev;
@@ -201,6 +254,12 @@ void board_init_f(ulong dummy)
 
 	ctrl_mmr_unlock();
 
+
+	/* RNO-G hook here */
+	if (CONFIG_IS_ENABLED(RNO_G_EARLY_BOOT)) {
+		rno_g_early_hook();
+	}
+
 	/* Init DM early */
 	spl_early_init();
 
